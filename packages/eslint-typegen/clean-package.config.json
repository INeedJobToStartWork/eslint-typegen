{
	"indent": 4,
	"remove": ["devDependencies", "dependencies", "lint-staged", "bin"],
	"replace": {
		"name": "/eslint-typegen",
		"type": "commonjs",
		"scripts": {
			"npm:postpack": "clean-package restore"
		},
		"bin": {
			"eslint-typegen": "./bin/app.mjs"
		},
		"main": "./index.cjs",
		"module": "./index.mjs",
		"exports": {
			".": {
				"import": {
					"types": "./index.d.mts",
					"default": "./index.mjs"
				},
				"require": {
					"types": "./index.d.cts",
					"default": "./index.cjs"
				}
			}
		}
	}
}
